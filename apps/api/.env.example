# Local API server
PORT=3100
HOST=0.0.0.0

# OpenClaw Gateway
# Local development can point to the Windows bridge at 127.0.0.1:18789.
# Server deployment should point directly to the same-host / same-LAN OpenClaw gateway.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=replace-with-your-gateway-token
OPENCLAW_AGENT_ID=main
# OPENCLAW_MODEL=openclaw:main

# Audit cleanup threshold
# Trigger auto cleanup only when remaining free storage drops below 20%.
AUDIT_STORAGE_MIN_FREE_RATIO=0.2

# Optional local UIE extraction service
ENABLE_PADDLE_UIE=0
PADDLE_UIE_PYTHON_BIN=C:\Users\soulzyn\develop\python-envs\paddle-uie-runtime310\Scripts\python.exe
PADDLE_UIE_MODEL=uie-base
