{
  "name": "ai-data-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "setup:env": "node tools/ensure-env.mjs",
    "dev": "corepack pnpm setup:env && corepack pnpm -r --parallel --filter ./apps/api --filter ./apps/web --filter ./apps/worker dev",
    "dev:api": "corepack pnpm --filter api dev",
    "dev:control-plane-api": "corepack pnpm --filter control-plane-api dev",
    "dev:control-plane-web": "corepack pnpm --filter control-plane-web dev",
    "dev:web": "corepack pnpm --filter web dev",
    "dev:worker": "corepack pnpm --filter worker dev",
    "openclaw:install": "powershell -ExecutionPolicy Bypass -File tools/install-openclaw-latest.ps1",
    "openclaw:workspace:init": "powershell -ExecutionPolicy Bypass -File tools/init-openclaw-workspace.ps1",
    "openclaw:skills:list": "corepack pnpm exec clawhub list --workdir .",
    "openclaw:skills:update": "corepack pnpm exec clawhub update --all --workdir .",
    "openclaw:memory:refresh": "corepack pnpm --filter api memory:refresh",
    "system:control": "corepack pnpm --filter api platform:control",
    "client:install": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action install",
    "client:preflight": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action preflight",
    "client:auth": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action auth",
    "client:model:lease": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action lease-model",
    "client:ui": "powershell -ExecutionPolicy Bypass -File tools/windows-client/bootstrap-launcher.ps1",
    "client:update:check": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action check-update",
    "client:update:download": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action download-update",
    "client:update:apply": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action apply-update",
    "client:update:background": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action background-update",
    "client:start": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action start",
    "client:stop": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action stop",
    "client:status": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action status",
    "client:bootstrap:build": "powershell -ExecutionPolicy Bypass -File tools/windows-client/build-bootstrap-package.ps1",
    "client:bootstrap:installer": "powershell -ExecutionPolicy Bypass -File tools/windows-client/build-bootstrap-installer.ps1",
    "client:release:build": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action build-release",
    "client:release:publish": "powershell -ExecutionPolicy Bypass -File tools/windows-client/manage-client.ps1 -Action publish-release",
    "local:start": "powershell -ExecutionPolicy Bypass -File tools/start-local.ps1",
    "local:stop": "powershell -ExecutionPolicy Bypass -File tools/stop-local.ps1",
    "local:status": "powershell -ExecutionPolicy Bypass -File tools/status-local.ps1",
    "smoke:local": "node tools/smoke-local.mjs",
    "smoke:local:cloud": "node tools/smoke-local.mjs --with-cloud",
    "smoke:remote:utf8": "node tools/smoke-remote.mjs",
    "check:remote:order": "node tools/check-remote-order.mjs",
    "sample:remote:resume": "node tools/sample-remote-resume-pages.mjs",
    "seed:default-samples": "node tools/seed-default-samples.mjs",
    "deploy:remote": "node tools/run-deploy-remote.mjs",
    "deploy:remote:preflight": "node tools/run-deploy-remote.mjs --preflight",
    "check:text-integrity": "node tools/check-text-integrity.mjs",
    "build": "corepack pnpm -r --filter ./apps/api --filter ./apps/control-plane-api --filter ./apps/control-plane-web --filter ./apps/web --filter ./apps/worker build",
    "test": "corepack pnpm --filter api test && corepack pnpm --filter control-plane-api test",
    "lint": "corepack pnpm check:text-integrity && corepack pnpm build"
  },
  "devDependencies": {
    "clawhub": "^0.9.0"
  }
}
