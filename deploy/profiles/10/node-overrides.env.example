# 10-specific node identity and home fallback settings.
# Replace the host values before applying on the real server.

HOME_PLATFORM_BASE_URL=http://<server-1-home-host>/platform-api/api
HOME_PLATFORM_BRIDGE_MODE=local-first
HOME_PLATFORM_PROJECT_KEY=ai-data-platform
HOME_PLATFORM_PRINCIPAL_KEY=server:<server-10-host>
HOME_PLATFORM_PRINCIPAL_LABEL=AI-10
HOME_PLATFORM_DEVICE_FINGERPRINT=bridge:<server-10-host>:18790
HOME_PLATFORM_PROVIDER=minimax
HOME_PLATFORM_MODEL=MiniMax-M2.7
