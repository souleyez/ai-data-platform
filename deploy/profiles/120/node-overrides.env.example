# 120-specific node identity and home fallback settings.
# Merge these values into /etc/ai-data-platform/ai-data-platform.env
# after copying the common deploy/server/ai-data-platform.env.example.

HOME_PLATFORM_BASE_URL=http://ad.goods-editor.com/platform-api/api
HOME_PLATFORM_BRIDGE_MODE=local-first
# Uncomment on nodes that run home-first and should keep a sticky server lease.
# HOME_PLATFORM_LEASE_PROFILE=server_120m
HOME_PLATFORM_PROJECT_KEY=ai-data-platform
HOME_PLATFORM_PRINCIPAL_KEY=server:120.24.251.24
HOME_PLATFORM_PRINCIPAL_LABEL=AI-120
HOME_PLATFORM_DEVICE_FINGERPRINT=bridge:120.24.251.24:18790
HOME_PLATFORM_PROVIDER=minimax
HOME_PLATFORM_MODEL=MiniMax-M2.7
