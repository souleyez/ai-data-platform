# Shared server deployment
NODE_ENV=production

# API
API_PORT=3100
API_HOST=127.0.0.1
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18790
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main
OPENCLAW_MODEL=deepseek/deepseek-chat
HOME_PLATFORM_TOKEN=
HOME_PLATFORM_BASE_URL=
HOME_PLATFORM_BRIDGE_MODE=local-first
HOME_PLATFORM_LEASE_PROFILE=
HOME_PLATFORM_LEASE_RENEW_INTERVAL_MS=
HOME_PLATFORM_PROJECT_KEY=ai-data-platform
HOME_PLATFORM_PRINCIPAL_KEY=
HOME_PLATFORM_PRINCIPAL_LABEL=
HOME_PLATFORM_DEVICE_FINGERPRINT=
HOME_PLATFORM_PROVIDER=
HOME_PLATFORM_MODEL=

# Model bridge
MODEL_BRIDGE_HOST=127.0.0.1
MODEL_BRIDGE_PORT=18790
DEEPSEEK_API_KEY=replace-with-server-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_CN_API_KEY=
MINIMAX_CN_BASE_URL=https://api.minimaxi.com/v1

# Web
WEB_PORT=3000
WEB_HOST=127.0.0.1
NEXT_PUBLIC_API_BASE_URL=
BACKEND_API_BASE_URL=http://127.0.0.1:3100

# Worker
WORKER_NAME=ingest-worker
WORKER_POLL_INTERVAL_MS=15000
WORKER_SCAN_PATH=/api/documents/scan
WORKER_DEEP_PARSE_PATH=/api/documents/deep-parse/run
WORKER_ENABLE_DEEP_PARSE=true
WORKER_DEEP_PARSE_BATCH_SIZE=4
DOCUMENT_DEEP_PARSE_PROVIDER=openclaw-chat
ENABLE_OPENCLAW_DOCUMENT_STRUCTURING=1
OPENCLAW_DOCUMENT_STRUCTURING_BATCH_LIMIT=12
OPENCLAW_DOCUMENT_STRUCTURING_CONCURRENCY=2
OPENCLAW_DOCUMENT_STRUCTURING_INPUT_LIMIT=7000
WORKER_ENABLE_AUDIT=true
WORKER_AUDIT_HOUR=2
WORKER_AUDIT_MINUTE=0
API_BASE_URL=http://127.0.0.1:3100
