[Unit]
Description=AI Data Platform Web
After=network-online.target ai-data-platform-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/srv/ai-data-platform/apps/web
EnvironmentFile=/srv/ai-data-platform/deploy/server/ai-data-platform.env
ExecStart=/bin/sh -lc '/usr/local/bin/node node_modules/next/dist/bin/next start -p ${WEB_PORT:-3000}'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
