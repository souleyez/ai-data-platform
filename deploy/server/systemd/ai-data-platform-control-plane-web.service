# Legacy migration reference only.
# Do not install this unit for new environments. Shared platform services now live in `home`.
[Unit]
Description=LEGACY AI Data Platform Control Plane Web
After=network-online.target ai-data-platform-control-plane-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/srv/ai-data-platform/apps/control-plane-web
EnvironmentFile=/etc/ai-data-platform/ai-data-platform.env
ExecStart=/bin/sh -lc '/usr/local/bin/node node_modules/next/dist/bin/next start -H ${CONTROL_PLANE_WEB_HOST:-127.0.0.1} -p ${CONTROL_PLANE_WEB_PORT:-3001}'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
